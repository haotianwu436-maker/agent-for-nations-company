POSTGRES_DB=media_ai
POSTGRES_USER=media_ai
POSTGRES_PASSWORD=media_ai
POSTGRES_PORT=5432

API_PORT=8000
WEB_PORT=3000

JWT_SECRET=replace_me
JWT_EXPIRE_MINUTES=120

DATABASE_URL=postgresql+psycopg://media_ai:media_ai@127.0.0.1:5432/media_ai
APP_NAME=media-ai-api
APP_ENV=dev
LOG_LEVEL=INFO

REPORT_WRITING_MODE=llm

LITELLM_BASE_URL=https://api.moonshot.cn/v1
LITELLM_API_KEY=replace_me
LITELLM_MODEL=openai/moonshot-v1-8k
LLM_TIMEOUT_SECONDS=30

CHROMA_PERSIST_DIR=/data/chroma
CHROMA_INTERNAL_COLLECTION_NAME=agent_internal_kb
BGE_EMBED_MODEL=BAAI/bge-large-zh-v1.5
KB_EXAMPLES_DIR=demo/kb_examples
DEFAULT_ORGANIZATION_ID=default-org

# Phase 2.5：章节 classifier 模式（默认 llm；rule 保留稳定兜底）
AGENT_CLASSIFIER_MODE=llm
AGENT_MIN_DOCS=6
AGENT_RETRIEVER_MAX_RETRIES=2
TIMEOUT_SECONDS=120
SOFT_TIMEOUT_SECONDS=60
HARD_TIMEOUT_SECONDS=120
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
